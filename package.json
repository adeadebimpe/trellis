{
  "name": "trellis",
  "displayName": "Trellis",
  "description": "Structure autonomous coding work from task to verified code.",
  "version": "0.1.1",
  "publisher": "adebimpe",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "media/marketplace-icon.png",
  "galleryBanner": {
    "color": "#151719",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": [
    "ai agents",
    "kanban",
    "codex",
    "claude code",
    "worktrees",
    "task orchestration",
    "code review"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-board",
          "title": "Trellis",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-board": [
        {
          "type": "webview",
          "id": "agentBoard.boardView",
          "name": "Trellis",
          "contextualTitle": "Trellis"
        }
      ]
    },
    "commands": [
      {
        "command": "agentBoard.openBoard",
        "title": "Trellis: Open Board"
      },
      {
        "command": "agentBoard.prepareAgentFiles",
        "title": "Trellis: Prepare Agent Files"
      },
      {
        "command": "agentBoard.configureAi",
        "title": "Trellis: Configure AI"
      },
      {
        "command": "agentBoard.clearAi",
        "title": "Trellis: Clear AI Settings"
      },
      {
        "command": "agentBoard.configureSpecProvider",
        "title": "Trellis: Configure Spec Generation"
      },
      {
        "command": "agentBoard.signInAgents",
        "title": "Trellis: Sign In to Agent CLI"
      },
      {
        "command": "agentBoard.signInCodex",
        "title": "Trellis: Sign In to Codex CLI"
      },
      {
        "command": "agentBoard.signInClaude",
        "title": "Trellis: Sign In to Claude Code"
      },
      {
        "command": "agentBoard.setupClaudeToken",
        "title": "Trellis: Generate Claude Automation Token"
      },
      {
        "command": "agentBoard.freshStart",
        "title": "Trellis: Fresh Start"
      }
    ],
    "configuration": {
      "title": "Trellis",
      "properties": {
        "agentBoard.gitignoreBoardDirectory": {
          "type": "boolean",
          "default": true,
          "title": "Git-ignore Board Directory",
          "description": "Add .agent-board/ to the workspace root .gitignore. Disable this if you intentionally commit Trellis tasks and project context."
        },
        "agentBoard.autoContinue": {
          "type": "boolean",
          "default": true,
          "title": "Automatically Continue Ready Tasks",
          "description": "Start the next highest-priority Ready for Agent task when no build terminal is running."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test:prd": "node tests/prdPrompt.test.mjs",
    "test:gitignore": "node tests/gitignore.test.mjs",
    "test:archive": "node tests/archive.test.mjs",
    "test:onboarding": "node tests/onboarding.test.mjs",
    "test:scripts": "node tests/scripts.test.mjs",
    "test": "npm run test:prd && npm run test:gitignore && npm run test:archive && npm run test:onboarding && npm run test:scripts",
    "typecheck": "tsc --noEmit",
    "compile": "npm run typecheck && npm run build",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
